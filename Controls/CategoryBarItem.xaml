<UserControl x:Class="LibraryManagementFE.Controls.CategoryBarItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Reusable row: category name | count | progress bar
        DPs: CategoryName, CategoryCount, Percentage (0-1), BarColor
    -->
    <StackPanel>
        <!-- Label row -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding CategoryName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14" FontWeight="Medium"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding CategoryCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Style="{StaticResource CategoryBar}"
                     Value="{Binding Percentage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Minimum="0" Maximum="1"
                     Foreground="{Binding BarColor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </StackPanel>
</UserControl>
