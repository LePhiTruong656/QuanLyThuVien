<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════
         Typography
    ═══════════════════════════════════════ -->
    <!-- Inter from Google Fonts if installed on machine, else Segoe UI -->
    <FontFamily x:Key="InterFont">Inter, Segoe UI, Arial</FontFamily>

    <Style x:Key="Text.Heading1" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"     Value="20"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="LineHeight"   Value="28"/>
    </Style>

    <Style x:Key="Text.Heading2" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"     Value="20"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextHeadingBrush}"/>
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"     Value="14"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="Text.Small" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="FontWeight"   Value="Normal"/>
        <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="FontWeight"   Value="Medium"/>
        <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="Text.TableHeader" TargetType="TextBlock">
        <Setter Property="FontFamily"           Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="FontWeight"           Value="Normal"/>
        <Setter Property="Foreground"           Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="TextDecorations"      Value="{x:Null}"/>
    </Style>

    <!-- ═══════════════════════════════════════
         Card  (white, border, shadow)
    ═══════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource WhiteBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270"
                                  Color="#000000" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         Sidebar nav link  –  Normal
    ═══════════════════════════════════════ -->
    <Style x:Key="NavLink" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"          Value="16,10"/>
        <Setter Property="Height"           Value="40"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavBorder" Property="Background"
                                    Value="{StaticResource Surface100Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="NavBorder" Property="Background"
                                    Value="{StaticResource Brand50Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar nav link  –  Active (selected) -->
    <Style x:Key="NavLink.Active" TargetType="Button" BasedOn="{StaticResource NavLink}">
        <Setter Property="Background" Value="{StaticResource BrandDeepBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar nav link  –  Danger (logout) -->
    <Style x:Key="NavLink.Danger" TargetType="Button" BasedOn="{StaticResource NavLink}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="DangerBorder"
                            Background="Transparent"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DangerBorder" Property="Background"
                                    Value="{StaticResource Danger100Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         Icon button (round, TopBar)
    ═══════════════════════════════════════ -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width"            Value="36"/>
        <Setter Property="Height"           Value="36"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="9999">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{StaticResource Surface100Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         Toggle button (chart filter)
    ═══════════════════════════════════════ -->
    <Style x:Key="ToggleChartBtn" TargetType="Button">
        <Setter Property="Height"           Value="24"/>
        <Setter Property="Padding"          Value="12,4"/>
        <Setter Property="Background"       Value="{StaticResource Surface100Brush}"/>
        <Setter Property="Foreground"       Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily"       Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToggleChartBtn.Active" TargetType="Button" BasedOn="{StaticResource ToggleChartBtn}">
        <Setter Property="Background" Value="{StaticResource BrandBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════
         Badge / Pill  (status chips)
    ═══════════════════════════════════════ -->
    <Style x:Key="Badge.Success" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Success100Brush}"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,4"/>
    </Style>

    <Style x:Key="Badge.Info" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Brand200Brush}"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,4"/>
    </Style>

    <Style x:Key="Badge.Danger" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Danger100Brush}"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,4"/>
    </Style>

    <!-- ═══════════════════════════════════════
         Link button ("Xem báo cáo chi tiết")
    ═══════════════════════════════════════ -->
    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontFamily"       Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="Foreground"       Value="{StaticResource BrandDarkBrush}"/>
        <Setter Property="Padding"          Value="0,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         DataGrid / ListView overrides
    ═══════════════════════════════════════ -->
    <Style x:Key="DataGridStyle" TargetType="DataGrid">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="RowBackground"            Value="{StaticResource WhiteBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource WhiteBrush}"/>
        <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        <Setter Property="AutoGenerateColumns"      Value="False"/>
        <Setter Property="CanUserResizeColumns"     Value="False"/>
        <Setter Property="CanUserReorderColumns"    Value="False"/>
        <Setter Property="CanUserSortColumns"       Value="True"/>
        <Setter Property="IsReadOnly"               Value="True"/>
        <Setter Property="SelectionMode"            Value="Single"/>
        <Setter Property="FontFamily"               Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"                 Value="14"/>
    </Style>

    <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background"       Value="{StaticResource Surface50Brush}"/>
        <Setter Property="Foreground"       Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily"       Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="FontWeight"       Value="Normal"/>
        <Setter Property="Padding"          Value="24,16"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="0,0,0,1"/>
        <Setter Property="Height"           Value="48"/>
    </Style>

    <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface50Brush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="Padding"          Value="24,0"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brand50Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════
         ScrollViewer / ScrollBar
    ═══════════════════════════════════════ -->
    <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ═══════════════════════════════════════
         Progress bar (category breakdown)
    ═══════════════════════════════════════ -->
    <Style x:Key="CategoryBar" TargetType="ProgressBar">
        <Setter Property="Height"           Value="8"/>
        <Setter Property="Background"       Value="{StaticResource Surface100Brush}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="4" Background="{TemplateBinding Background}">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Background="{TemplateBinding Foreground}"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         Pagination Button
    ═══════════════════════════════════════ -->
    <Style x:Key="PageBtn" TargetType="Button">
        <Setter Property="Height"           Value="32"/>
        <Setter Property="MinWidth"         Value="32"/>
        <Setter Property="Padding"          Value="8,0"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontFamily"       Value="{StaticResource InterFont}"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="Foreground"       Value="#64748B"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#F1F5F9"/>
                            <Setter Property="Foreground" Value="#0F172A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PageBtn.Active" TargetType="Button" BasedOn="{StaticResource PageBtn}">
        <Setter Property="Background" Value="#E2E8F0"/>
        <Setter Property="Foreground" Value="#0F172A"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
