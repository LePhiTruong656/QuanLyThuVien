<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         Brand / Primary
    ═══════════════════════════════════════ -->
    <Color x:Key="Brand900">#004A99</Color>
    <Color x:Key="Brand700">#0045BD</Color>
    <Color x:Key="Brand500">#135BEC</Color>
    <Color x:Key="Brand200">#D0E1FB</Color>
    <Color x:Key="Brand100">#DBEAFE</Color>
    <Color x:Key="Brand50">#EFF6FF</Color>

    <!-- ═══════════════════════════════════════
         Neutral / Slate
    ═══════════════════════════════════════ -->
    <Color x:Key="Slate950">#0F172A</Color>
    <Color x:Key="Slate900">#191B24</Color>
    <Color x:Key="Slate700">#334155</Color>
    <Color x:Key="Slate600">#475569</Color>
    <Color x:Key="Slate500">#64748B</Color>
    <Color x:Key="Slate400">#94A3B8</Color>
    <Color x:Key="Slate200">#E2E8F0</Color>
    <Color x:Key="Slate100">#F1F5F9</Color>
    <Color x:Key="Slate50">#F8FAFC</Color>

    <!-- ═══════════════════════════════════════
         Semantic – Success / Green
    ═══════════════════════════════════════ -->
    <Color x:Key="Green700">#15803D</Color>
    <Color x:Key="Green600">#16A34A</Color>
    <Color x:Key="Green100">#DCFCE7</Color>
    <Color x:Key="Green50">#F0FDF4</Color>

    <!-- ═══════════════════════════════════════
         Semantic – Error / Red
    ═══════════════════════════════════════ -->
    <Color x:Key="Red700">#BA1A1A</Color>
    <Color x:Key="Red100">#FFDAD6</Color>
    <Color x:Key="Red50Transparent">#33FFDAD6</Color>
    <Color x:Key="Red100Transparent">#66FFDAD6</Color>

    <!-- ═══════════════════════════════════════
         Semantic – Cyan / Info
    ═══════════════════════════════════════ -->
    <Color x:Key="Cyan500">#06B6D4</Color>
    <Color x:Key="Cyan50">#ECFEFF</Color>

    <!-- ═══════════════════════════════════════
         Semantic – Purple
    ═══════════════════════════════════════ -->
    <Color x:Key="Purple500">#9333EA</Color>
    <Color x:Key="Purple100">#FAF5FF</Color>

    <!-- ═══════════════════════════════════════
         Surface
    ═══════════════════════════════════════ -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Background">#F6F6F8</Color>
    <Color x:Key="BackgroundPage">#FAF8FF</Color>

    <!-- ═══════════════════════════════════════
         SolidColorBrushes
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="BrandBrush"       Color="{StaticResource Brand500}"/>
    <SolidColorBrush x:Key="BrandDarkBrush"   Color="{StaticResource Brand700}"/>
    <SolidColorBrush x:Key="BrandDeepBrush"   Color="{StaticResource Brand900}"/>
    <SolidColorBrush x:Key="Brand100Brush"    Color="{StaticResource Brand100}"/>
    <SolidColorBrush x:Key="Brand200Brush"    Color="{StaticResource Brand200}"/>
    <SolidColorBrush x:Key="Brand50Brush"     Color="{StaticResource Brand50}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource Slate950}"/>
    <SolidColorBrush x:Key="TextHeadingBrush"   Color="{StaticResource Slate900}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Slate700}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource Slate500}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"  Color="{StaticResource Slate400}"/>

    <SolidColorBrush x:Key="BorderBrush"     Color="{StaticResource Slate200}"/>
    <SolidColorBrush x:Key="Surface50Brush"  Color="{StaticResource Slate50}"/>
    <SolidColorBrush x:Key="Surface100Brush" Color="{StaticResource Slate100}"/>
    <SolidColorBrush x:Key="WhiteBrush"      Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BgBrush"         Color="{StaticResource Background}"/>

    <SolidColorBrush x:Key="Green700Brush"   Color="{StaticResource Green700}"/>
    <SolidColorBrush x:Key="SuccessBrush"    Color="{StaticResource Green600}"/>
    <SolidColorBrush x:Key="Success100Brush" Color="{StaticResource Green100}"/>
    <SolidColorBrush x:Key="Success50Brush"  Color="{StaticResource Green50}"/>

    <SolidColorBrush x:Key="DangerBrush"     Color="{StaticResource Red700}"/>
    <SolidColorBrush x:Key="Danger100Brush"  Color="{StaticResource Red100}"/>

    <SolidColorBrush x:Key="CyanBrush"       Color="{StaticResource Cyan500}"/>
    <SolidColorBrush x:Key="Cyan50Brush"     Color="{StaticResource Cyan50}"/>

    <SolidColorBrush x:Key="PurpleBrush"     Color="{StaticResource Purple500}"/>
    <SolidColorBrush x:Key="Purple100Brush"  Color="{StaticResource Purple100}"/>

    <!-- Drop shadow emulation (used as Border backgrounds) -->
    <SolidColorBrush x:Key="ShadowColorBrush" Color="#0D000000"/>

</ResourceDictionary>
