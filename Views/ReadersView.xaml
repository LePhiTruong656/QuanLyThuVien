<UserControl x:Class="LibraryManagementFE.Views.ReadersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryManagementFE.ViewModels"
             xmlns:models="clr-namespace:LibraryManagementFE.Models"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:ReadersViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,32,32,32">

            <!-- ══ TOOLBAR ══ -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Grid Grid.Column="0">
                    <!-- Icon -->
                    <Viewbox Width="18" Height="18"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Margin="14,0,0,0"
                             Panel.ZIndex="1">
                        <Canvas Width="18" Height="18">
                            <Ellipse Canvas.Left="1" Canvas.Top="1" Width="12" Height="12"
                                     Stroke="#94A3B8" StrokeThickness="1.5" Fill="Transparent"/>
                            <Line X1="11" Y1="11" X2="17" Y2="17"
                                  Stroke="#94A3B8" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <!-- Input -->
                    <TextBox x:Name="TxtSearch"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="48"
                             Padding="46,0,16,0"
                             VerticalContentAlignment="Center"
                             FontFamily="{StaticResource InterFont}"
                             FontSize="14"
                             Foreground="#0F172A"
                             Background="White"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="12">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1"
                                                                      Direction="270" Color="#000000" Opacity="0.05"/>
                                                </Border.Effect>
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Padding="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Placeholder -->
                    <TextBlock Text="Tìm tên, email hoặc mã thẻ..."
                               FontFamily="{StaticResource InterFont}"
                               FontSize="14" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="48,0,16,0"
                               IsHitTestVisible="False" Panel.ZIndex="1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Filter button -->
                <Button Grid.Column="2"
                        Command="{Binding FilterCommand}"
                        Height="48" Padding="20,0"
                        Background="White"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Direction="270"
                                                      Color="#000000" Opacity="0.05"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                        <Canvas Width="16" Height="16">
                                            <Line X1="2" Y1="4" X2="14" Y2="4" Stroke="#334155" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="4" Y1="8" X2="12" Y2="8" Stroke="#334155" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="6" Y1="12" X2="10" Y2="12" Stroke="#334155" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Bộ lọc"
                                               FontFamily="{StaticResource InterFont}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Lập thẻ mới button -->
                <Button Grid.Column="4"
                        Command="{Binding AddReaderCommand}"
                        Height="48" Padding="28,0"
                        Background="#005AB4"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="4"
                                                      Direction="270" Color="#005AB4" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Canvas Width="14" Height="14">
                                            <Line X1="7" Y1="2" X2="7" Y2="12" Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="2" Y1="7" X2="12" Y2="7" Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Lập thẻ mới"
                                               FontFamily="{StaticResource InterFont}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#004A99"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ══ READERS TABLE ══ -->
            <Border Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="16" Margin="0,0,0,32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270"
                                      Color="#000000" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding PagedReaders}"
                              Height="408"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E2E8F0"
                              VerticalGridLinesBrush="Transparent"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionMode="Single"
                              FontFamily="{StaticResource InterFont}"
                              FontSize="14"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}">

                        <DataGrid.Columns>

                            <!-- Col 1: Độc giả (avatar + name + email) -->
                            <DataGridTemplateColumn Header="ĐỘC GIẢ" Width="*" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ReaderRecord}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Avatar circle -->
                                            <Border Width="36" Height="36" CornerRadius="9999"
                                                    BorderThickness="1" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding AvatarBackground}"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="{Binding AvatarBorder}"/>
                                                </Border.BorderBrush>
                                                <TextBlock Text="{Binding Initials}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding AvatarForeground}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                            <!-- Name + email -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding Email}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Col 2: Mã thẻ -->
                            <DataGridTemplateColumn Header="MÃ THẺ" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ReaderRecord}">
                                        <TextBlock Text="{Binding CardNumber}"
                                                   FontFamily="Consolas, Courier New"
                                                   FontSize="13" Foreground="#64748B"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Col 3: Ngày đăng ký -->
                            <DataGridTextColumn Header="NGÀY ĐĂNG KÝ"
                                                Binding="{Binding RegDate}"
                                                Width="140"
                                                ElementStyle="{StaticResource Text.Body}"/>

                            <!-- Col 4: Loại thẻ badge -->
                            <DataGridTemplateColumn Header="LOẠI THẺ" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ReaderRecord}">
                                        <Border CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding CardTypeBg}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding CardTypeText}"
                                                       FontFamily="{StaticResource InterFont}"
                                                       FontSize="10" FontWeight="Bold">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding CardTypeFg}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Col 5: Trạng thái -->
                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ReaderRecord}">
                                        <Border CornerRadius="9999" Padding="10,4"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding StatusBg}"/>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding StatusDotColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="12" FontWeight="Medium"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding StatusTextColor}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Col 6: Thao tác -->
                            <DataGridTemplateColumn Header="THAO TÁC" Width="100">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridColumnHeaderStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource IconButton}"
                                                HorizontalAlignment="Right"
                                                ToolTip="Xem chi tiết"
                                                Click="BtnRowMenu_Click"
                                                Tag="{Binding}">
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                <Ellipse Width="3.5" Height="3.5" Fill="#64748B" Margin="0,0,0,2"/>
                                                <Ellipse Width="3.5" Height="3.5" Fill="#64748B" Margin="0,0,0,2"/>
                                                <Ellipse Width="3.5" Height="3.5" Fill="#64748B"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                            Background="#F9FAFB" CornerRadius="0,0,16,16">
                        <Grid Margin="24,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Info text -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PaginationInfo}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                            <!-- Page buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Trước"
                                        Command="{Binding PrevPageCommand}"
                                        Style="{StaticResource PageBtn}"
                                        Margin="0,0,4,0"/>
                                <ItemsControl ItemsSource="{Binding PageNumbers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Number}"
                                                    Command="{Binding DataContext.GoToPageCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Number}"
                                                    Margin="0,0,4,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource Books.PageNumberButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Background" Value="#005AB4"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Sau"
                                        Command="{Binding NextPageCommand}"
                                        Style="{StaticResource PageBtn}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══ QUICK STATS BENTO ══ -->
            <UniformGrid Rows="1" Columns="4">

                <!-- Stat 1: Mới tháng này -->
                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="24,24,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="#0D2E660D" Margin="0,0,12,0">
                            <Viewbox Width="22" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="22" Height="16">
                                    <Rectangle Canvas.Left="1" Canvas.Top="1" Width="20" Height="14" RadiusX="2" RadiusY="2"
                                               Stroke="#004A99" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="4" Y1="6" X2="18" Y2="6" Stroke="#004A99" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="4" Y1="9.5" X2="18" Y2="9.5" Stroke="#004A99" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="4" Y1="13" X2="12" Y2="13" Stroke="#004A99" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MỚI THÁNG NÀY"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding NewThisMonth}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stat 2: Tổng độc giả -->
                <Border Style="{StaticResource Card}" Margin="6,0,6,0" Padding="24,24,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="#0D2E660D" Margin="0,0,12,0">
                            <Viewbox Width="18" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="18" Height="14">
                                    <Ellipse Canvas.Left="1" Canvas.Top="0.5" Width="6.5" Height="6.5"
                                             Stroke="#004A99" StrokeThickness="1.4" Fill="Transparent"/>
                                    <Ellipse Canvas.Left="10" Canvas.Top="0.5" Width="6.5" Height="6.5"
                                             Stroke="#004A99" StrokeThickness="1.4" Fill="Transparent"/>
                                    <Path Data="M0 14 Q0 9.5 4.25 9.5 Q9 9.5 9 14"
                                          Stroke="#004A99" StrokeThickness="1.4" StrokeLineJoin="Round" Fill="Transparent"/>
                                    <Path Data="M9 14 Q9 9.5 13.25 9.5"
                                          Stroke="#004A99" StrokeThickness="1.4" StrokeLineJoin="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TỔNG ĐỘC GIẢ"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TotalReaders}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stat 3: Hết hạn -->
                <Border Style="{StaticResource Card}" Margin="6,0,6,0" Padding="24,24,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="#FFFBEB" BorderBrush="#FEF3C7" BorderThickness="1"
                                Margin="0,0,12,0">
                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="18" Height="18">
                                    <Ellipse Canvas.Left="1" Canvas.Top="1" Width="16" Height="16"
                                             Stroke="#D97706" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Line X1="9" Y1="5.5" X2="9" Y2="9.5"
                                          Stroke="#D97706" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Ellipse Canvas.Left="8" Canvas.Top="12" Width="2" Height="2"
                                             Fill="#D97706"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="HẾT HẠN"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ExpiredReaders}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stat 4: Đang hoạt động -->
                <Border Style="{StaticResource Card}" Margin="12,0,0,0" Padding="24,24,24,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="10"
                                Background="#ECFDF5" BorderBrush="#D1FAE5" BorderThickness="1"
                                Margin="0,0,12,0">
                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="18" Height="18">
                                    <Path Data="M4 9.5 L7.5 13 L14 5"
                                          Stroke="#059669" StrokeThickness="1.8"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ĐANG HOẠT ĐỘNG"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ActiveReaders}"
                                       FontFamily="{StaticResource InterFont}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#0F172A"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
