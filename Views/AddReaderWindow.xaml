<Window x:Class="LibraryManagementFE.Views.AddReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lập thẻ mới"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Margin="0"
            Padding="24"
            Background="{StaticResource WhiteBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Lập thẻ mới"
                           FontFamily="{StaticResource InterFont}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Margin="0,4,0,0"
                           Text="Nhập thông tin độc giả để tạo thẻ thư viện."
                           FontFamily="{StaticResource InterFont}"
                           FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                    <TextBlock Style="{StaticResource FormLabel}" Text="Họ tên"/>
                    <TextBox x:Name="NameTextBox" Style="{StaticResource FormTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                    <TextBlock Style="{StaticResource FormLabel}" Text="Email"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource FormTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0">
                    <TextBlock Style="{StaticResource FormLabel}" Text="Ngày sinh"/>
                    <DatePicker x:Name="DateOfBirthPicker"
                                Height="40"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="2">
                    <TextBlock Style="{StaticResource FormLabel}" Text="Loại thẻ"/>
                    <ComboBox x:Name="CardTypeComboBox"
                              Style="{StaticResource FormComboBox}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Sinh viên"/>
                        <ComboBoxItem Content="Giáo viên"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="8" Grid.Column="0"/>
            </Grid>

            <TextBlock x:Name="ErrorTextBlock"
                       Grid.Row="3"
                       Visibility="Collapsed"
                       VerticalAlignment="Bottom"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="13"
                       Foreground="{StaticResource DangerBrush}"/>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Hủy"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"
                        IsCancel="True"/>
                <Button Style="{StaticResource Books.PrimaryButton}"
                        MinWidth="128"
                        Padding="22,0"
                        Click="SaveButton_Click">
                    <TextBlock Text="Lưu thẻ"
                               FontFamily="{StaticResource InterFont}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
